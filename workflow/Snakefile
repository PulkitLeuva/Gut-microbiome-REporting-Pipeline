configfile: "config/config.yml"
home= config["home_dir"]
sample= ["0BPXYVnew"]
index_dir = "/home/kumardeep/Gut-microbiome-REporting-Pipeline/Homo_sapiens_hg37_and_human_contamination_Bowtie2_v0.1/hg37dec_v0.1"

