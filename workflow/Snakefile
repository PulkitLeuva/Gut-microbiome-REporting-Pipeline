        expand(f"{home}/output/Trimmed/{{sample}}_R1_unpaired_trim.fastq.gz", home= home,sample=sample),
        expand(f"{home}/output/Trimmed/{{sample}}_R2_paired_trim.fastq.gz",home= home, sample=sample),
        expand(f"{home}/output/Trimmed/{{sample}}_R2_unpaired_trim.fastq.gz",home= home, sample=sample),
        expand(f"{home}/output/Trimmed/{{sample}}_trimmomatic_summary.txt",home= home, sample=sample),
        expand(f"{home}/output/Trimmed/{{sample}}_trimmomatic_log.txt",home= home, sample=sample),
