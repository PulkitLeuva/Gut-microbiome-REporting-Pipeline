        metadata = expand(f"{home}/output/metaphlan_plots/{{sample}}_metadata.csv",home= home, sample=sample),
        pdf = expand(f"{home}/output/metaphlan_plots/{{sample}}_Gut_microbiome.pdf",home= home, sample=sample)
    
rule fastqc:
    input:
        fastq1 = f"{home}/input/fastq/{{sample}}_R1_001.fastq.gz",
        fastq2 = f"{home}/input/fastq/{{sample}}_R2_001.fastq.gz"
    output:
        outdir = directory(f"{home}/output/fastqc/{{sample}}")
    log:
        log = f"{home}/logs/{{sample}}.fastqc.log"
    benchmark:
        f"{home}/benchmark/{{sample}}_fastqc.tsv"
    message: "Executing fastqc on sample {wildcards.sample}."
    shell:
        """
        mkdir {home}/output/fastqc/{wildcards.sample}
        fastqc --outdir {output.outdir} {input.fastq1} {input.fastq2} > {log}
        """
rule bowtie2_align:
    input:
        fastq1 = f"{home}/input/fastq/{{sample}}_R1_001.fastq.gz",
        fastq2 = f"{home}/input/fastq/{{sample}}_R2_001.fastq.gz"
    output:
        unaligned1 = f"{home}/output/Aligned/{{sample}}_HR.fastq.1.gz",
        unaligned2 = f"{home}/output/Aligned/{{sample}}_HR.fastq.2.gz"
    params:
        index = index_dir,
        threads = 40,
        unaligned_dir = f"{home}/output/Aligned"
    resources:
        mem_mb=250000,
    log:
        f"{home}/logs/{{sample}}.bowtie2.log"
    benchmark:
        f"{home}/benchmark/{{sample}}_bowtie2.tsv"
    shell:
        """
        bowtie2 -x {params.index} -1 {input.fastq1} -2 {input.fastq2} \
        --un-conc-gz {params.unaligned_dir}/{wildcards.sample}_HR.fastq.%.gz \
        --threads {params.threads} -q --time 2> {log}
        """

# Define the rule for trimming reads using Trimmomatic
rule trimmomatic_trim:
    input:
        fastq1 = f"{home}/output/Aligned/{{sample}}_HR.fastq.1.gz",
        fastq2 = f"{home}/output/Aligned/{{sample}}_HR.fastq.2.gz"
    output:
        paired1 = f"{home}/output/Trimmed/{{sample}}_R1_paired_trim.fastq.gz",
        unpaired1 = f"{home}/output/Trimmed/{{sample}}_R1_unpaired_trim.fastq.gz",
        paired2 = f"{home}/output/Trimmed/{{sample}}_R2_paired_trim.fastq.gz",
        unpaired2 = f"{home}/output/Trimmed/{{sample}}_R2_unpaired_trim.fastq.gz",
        summary = f"{home}/output/Trimmed/{{sample}}_trimmomatic_summary.txt",
        trimlog = f"{home}/output/Trimmed/{{sample}}_trimmomatic_log.txt"
    benchmark:
        f"{home}/benchmark/{{sample}}_trimmomatic.tsv"
    params:
        threads = 40
    shell:
        """
        trimmomatic PE -phred33 {input.fastq1} {input.fastq2} \
        {output.paired1} {output.unpaired1} \
        {output.paired2} {output.unpaired2} \
        LEADING:30 TRAILING:30 SLIDINGWINDOW:4:20 MINLEN:70 \
        -threads {params.threads} \
        -summary {output.summary} \
        -trimlog {output.trimlog}
        """

rule metaphlan_profile:
    input:
        paired1 = f"{home}/output/Trimmed/{{sample}}_R1_paired_trim.fastq.gz",
        paired2 = f"{home}/output/Trimmed/{{sample}}_R2_paired_trim.fastq.gz"
    output:
        bowtie2out = f"{home}/output/mpa4_bowtie_out/{{sample}}.bowtie2.bz2",
        profile = f"{home}/output/metaphlan/{{sample}}_profiled_mpa4.txt"
    params:
        bowtie2db = f"{home}",
        threads = 40
    log:
        f"{home}/logs/{{sample}}.metaphlan.log"
    benchmark:
        f"{home}/benchmark/{{sample}}_metaphlan.tsv"
    conda:
        config["metaphlan_env"]
    shell:
        """
        metaphlan {input.paired1},{input.paired2} \
        --input_type fastq \
        --add_viruses \
        --sample_id {wildcards.sample}\
        --bowtie2out {output.bowtie2out} \
        --nproc {params.threads} \
        -o {output.profile} \
        --bowtie2db {params.bowtie2db} \
        > {log} 2>&1
        """
        
rule install_r_packages:
    input:
        f"{home}/scripts/install_packages.R"
    output:
        "logs/r_packages_installed.log"
    conda:
        config["r_env_yaml"]
    shell:
        """
        Rscript {input}
        echo "R packages installed" > {output}
        """

